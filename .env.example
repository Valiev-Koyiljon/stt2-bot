# Telegram bot token (from @BotFather)
TELEGRAM_BOT_TOKEN=

# ASR service endpoint and credentials
ASR_API_URL=http://185.100.53.247:7190/asr
ASR_API_KEY=aifirstm
ASR_LANG=uz  # language code (e.g., uz)

# Chunk length in seconds (max 30 seconds recommended)
ASR_CHUNK_SECONDS=30

# Optional: path to ffmpeg if not in PATH
# FFMPEG_PATH=/usr/local/bin/ffmpeg

# Optional: your Telegram chat ID to receive a copy of every transcript
# Use /id in the bot chat to get it
# ADMIN_CHAT_ID=

# API server settings
API_HOST=0.0.0.0
API_PORT=8000
RECENT_LIMIT=100

# Optional: protect API endpoints with X-API-Key header
# API_ACCESS_KEY=change-me

# Optional: webhook to receive JSON payload for each transcript
# WEBHOOK_URL=https://your-server.example.com/webhook
# WEBHOOK_TIMEOUT=10
